# StackSense Environment Variables

# API Server
PORT=3001
FRONTEND_URL=http://localhost:3000

# Redis
REDIS_URL=redis://localhost:6379

# Hiro API (for blockchain data)
HIRO_API_BASE=https://api.hiro.so
HIRO_API_KEY=your_hiro_api_key_here

# CoinGecko API (for STX price)
COINGECKO_API_URL=https://api.coingecko.com/api/v3

# Telegram Alerts (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHANNEL_ID=your_telegram_channel_id

# GitHub Integration (new - for developer tracking)
GITHUB_TOKEN=your_github_token_here

# Smart Contract Addresses (mainnet)
SIGNAL_TIPS_CONTRACT_ADDRESS=SP3DBM7M6CEM4BW7XQX5VGH7KRC64FD11X3N1D2DV.signal-tips
SUBSCRIPTIONS_CONTRACT_ADDRESS=SP3DBM7M6CEM4BW7XQX5VGH7KRC64FD11X3N1D2DV.stacksense-subscriptions

# Wallet (for transaction signing - if needed)
STACKS_PRIVATE_KEY=your_private_key_for_contract_operations

# Feature Flags
ENABLE_WEBHOOKS=true
ENABLE_SUBSCRIPTIONS=true
ENABLE_GITHUB_TRACKING=true
ENABLE_TIPS=true
