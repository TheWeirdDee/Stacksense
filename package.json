{
  "name": "stacksense",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:all": "npm run dev",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "build:api": "npm run build --workspace=apps/api",
    "build:web": "npm run build --workspace=apps/web",
    "divine": "npx tsx --max-old-space-size=4096 private/scripts/divine.ts",
    "npm-boost": "npx tsx private/scripts/npm-boost.ts"

  },

  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "pino": "^9.6.0",
    "pino-pretty": "^13.1.3",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  }
}
